---
import Layout from '~/layouts/PageLayout.astro';
const metadata = {
  title: 'Kalász Autószerviz',
  description: 'Autószerelés, szerviz, gumicsere, diagnosztika',
};
---

<Layout metadata={metadata}>
  <main class="min-h-screen bg-[#0a0a0a] text-white">
    <!-- Hero -->
    <section class="pt-24 pb-16 bg-gradient-to-br from-[#111] to-black">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-6">
          Kalász Autószerviz
        </h1>
        <p class="text-2xl text-red-500 font-semibold mb-4">
          Q-Service Partner
        </p>
        <p class="text-xl text-gray-300 mb-10 max-w-2xl mx-auto">
          Professzionális autószerelés, gumicsere, diagnosztika és javítások. 
          Gyors, megbízható szolgáltatás.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+36XXXXXXXXX" 
             class="bg-red-600 hover:bg-red-700 px-8 py-4 rounded-full text-lg font-semibold inline-flex items-center justify-center">
            Hívjon most
          </a>
          <a href="#szolgaltatasok" 
             class="border border-gray-500 hover:border-white px-8 py-4 rounded-full text-lg font-semibold">
            Szolgáltatásaink
          </a>
        </div>
      </div>
    </section>

    <!-- Szolgáltatások -->
    <section id="szolgaltatasok" class="py-20 bg-[#111]">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-4xl font-bold text-center mb-12">Szolgáltatásaink</h2>
        
        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-[#1a1a1a] p-8 rounded-2xl">
            <h3 class="text-2xl font-semibold mb-4 text-red-500">Motorjavítás & Szerviz</h3>
            <p class="text-gray-400">Teljes körű motordiagnosztika, javítás, karbantartás.</p>
          </div>
          <div class="bg-[#1a1a1a] p-8 rounded-2xl">
            <h3 class="text-2xl font-semibold mb-4 text-red-500">Gumicsere & Futómű</h3>
            <p class="text-gray-400">Gumicsere, balanszírozás, futómű javítás.</p>
          </div>
          <div class="bg-[#1a1a1a] p-8 rounded-2xl">
            <h3 class="text-2xl font-semibold mb-4 text-red-500">Diagnosztika</h3>
            <p class="text-gray-400">Modern számítógépes hibakeresés.</p>
          </div>
          <div class="bg-[#1a1a1a] p-8 rounded-2xl">
            <h3 class="text-2xl font-semibold mb-4 text-red-500">Egyéb Javítások</h3>
            <p class="text-gray-400">Fék, kuplung, hűtés, elektromos hibák.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Kapcsolat -->
    <section class="py-20 bg-black">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <h2 class="text-4xl font-bold mb-8">Keressen minket</h2>
        <p class="text-2xl mb-6">📍 Cím: [Ide írd a címed]</p>
        <p class="text-2xl mb-6">📞 Telefon: [Ide írd a számod]</p>
        <p class="text-xl text-gray-400">Hétfő–Péntek: 8:00 - 18:00</p>
      </div>
    </section>
  </main>
</Layout>
